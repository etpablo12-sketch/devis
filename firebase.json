{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "rules_version = '2';",
    "indexes": "{"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Davis",
        "supportEmail": "support@undefined.firebaseapp.com"
      }
    }
  }
}
