# Copy to .env and fill from Firebase Console → Project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Analytics (GA4) — from same console block as other web config
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: comma-separated emails that receive role "admin" on first profile create
# VITE_BOOTSTRAP_ADMIN_EMAILS=you@company.com
#
# If you use bootstrap emails, also add the same addresses in Firestore so security rules
# match the app (Console → Firestore → collection "config" → document "bootstrapAdmins"):
#   Field: emailAllow (map). For each admin email add key = exact Auth email, value = true (boolean).
